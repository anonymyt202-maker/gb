# ========== SERVER ==========
NODE_ENV=production
PORT=3000
WEBAPP_URL=https://example.com

# ========== DATABASE ==========
DATABASE_PATH=./giftbot.db

# ========== TELEGRAM BOT ==========
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321
MANDATORY_CHANNEL=@your_channel_name

# ========== WEBHOOK (Production Only) ==========
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_PATH=/webhook

# ========== JWT ==========
JWT_SECRET=your_jwt_secret_key_change_in_production

# ========== CURRENCY CONVERSION ==========
# 1 RM Coin = 1 Telegram Star = 150 UZS
RM_COIN_TO_STARS=1
RM_COIN_TO_UZS=150

# ========== GAME SETTINGS ==========
MIN_BET=1
MAX_BET=10000
MINES_BOMB_COUNT=5
SLOTS_MULTIPLIER_MATCH_ALL=5
SLOTS_MULTIPLIER_MATCH_TWO=2

# ========== REFERRAL SETTINGS ==========
REFERRAL_REWARD_PERCENT=1
REFERRAL_BONUS_STARS=1

# ========== PROMO CODE SETTINGS ==========
PROMO_MAX_USES=100
